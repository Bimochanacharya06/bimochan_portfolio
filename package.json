{
  "name": "bimochan-portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio site for Bimochan Acharya — Full Stack Developer",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint \"**/*.html\" --ignore \"node_modules/**\"",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\" --ignore-path .prettierignore",
    "build:css": "node scripts/build-css.js",
    "build:js": "node scripts/build-js.js",
    "build": "npm run build:css && npm run build:js",
    "prebuild": "mkdir -p dist/css dist/js"
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "prettier": "^3.3.3",
    "lightningcss": "^1.25.1",
    "terser": "^5.31.6"
  }
}
